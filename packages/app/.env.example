# Neynar API Key (Farcaster user lookups)
# Get your API key from https://dev.neynar.com/
NEYNAR_API_KEY=your_api_key_here

# Pinata IPFS (for uploading token metadata)
# Get your keys from https://pinata.cloud/
PINATA_API_KEY=your_api_key_here
PINATA_SECRET_KEY=your_secret_key_here
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud
NEXT_PUBLIC_PINATA_GATEWAY_KEY=your_gateway_key_here

# Base RPC URL (recommended to avoid rate limits)
# Get a free RPC URL from https://www.alchemy.com/
NEXT_PUBLIC_BASE_RPC_URL=

# Launchpad Subgraph URL (Goldsky)
NEXT_PUBLIC_LAUNCHPAD_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cmgscxhw81j5601xmhgd42rej/subgraphs/givedotfun/1.0.0/gn
